{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.19.4"
    },
    "develop": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "develop",
      "env": {
        "APP_ENV": "develop",
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-develop-97e5.up.railway.app"
      }
    },
    "develop-simulator": {
      "extends": "develop",
      "ios": {
        "simulator": true
      }
    },
    "storybook": {
      "extends": "develop",
      "env": {
        "STORYBOOK_ENABLED": "true"
      }
    },
    "stage": {
      "extends": "base",
      "distribution": "internal",
      "channel": "stage",
      "env": {
        "APP_ENV": "stage",
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-stage-9c63.up.railway.app"
      }
    },
    "stage-simulator": {
      "extends": "stage",
      "ios": {
        "simulator": true
      }
    },
    "master": {
      "extends": "base",
      "channel": "master",
      "env": {
        "APP_ENV": "master",
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-production-1e15.up.railway.app"
      }
    },
    "master-simulator": {
      "extends": "master",
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    }
  },
  "submit": {
    "master": {
      "ios": {
        "appleId": "jaemin@cheunjm.com",
        "ascAppId": "TODO",
        "appleTeamId": "2ZM4PS6CMF"
      }
    }
  }
}
