# Backend services
DATABASE_URL=postgresql://postgres:postgres@db.example.supabase.co:5432/postgres
NODE_ENV=development

# Apollo Router (used by rover dev / npm run dev:router)
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:3000,exp://192.168.0.87:8081

# Subgraph → tRPC (override when running outside Docker)
TRPC_SERVICE_URL=http://localhost:4000
